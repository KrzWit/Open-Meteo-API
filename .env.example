POSTGRES_USER=etl_user
POSTGRES_PASSWORD=etl_password
POSTGRES_DB=weather_etl
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://etl_user:etl_password@db:5432/weather_etl
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
REQUEST_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

# Format: CityName:latitude:longitude;CityName:latitude:longitude
CITY_DEFINITIONS=Warsaw:52.2297:21.0122;Berlin:52.5200:13.4050;Paris:48.8566:2.3522
